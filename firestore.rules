rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'ADMINISTRADOR';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── T-6.1 | libros: todos los autenticados leen; solo admin escribe ──────
    match /libros/{libroId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── T-6.1 | categorias: ídem libros ──────────────────────────────────────
    match /categorias/{categoriaId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── T-6.3 | users: cada usuario solo accede a su propio documento ─────────
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── T-6.2 | readingProgress: solo el propio usuario ──────────────────────
    match /users/{uid}/readingProgress/{libroId} {
      allow read, write: if isOwner(uid);
    }
  }
}
